# VisionPilot configuration template
#   cp config/vision_pilot.conf.example config/vision_pilot.conf

# ─── Input source ────────────────────────────────────────────────────────────
source.mode             = video
source.video_path       = ~/Downloads/data/zod/videos/001400_camera_front_blur_10fps.mp4
source.video_realtime   = true
source.video_loop       = false

source.ros2_topic       = /camera/image
source.v4l2_device      = /dev/video0
source.v4l2_fps         = 10

# ─── ONNX models ───────────────────────────────────────────────────────────────
models.autodrive_path = ~/Downloads/autodrive.onnx
models.autosteer_path = ~/Downloads/autosteer_2.0.onnx
models.autospeed_path = ~/Downloads/autospeed_2.onnx

engine.provider     = cpu
engine.precision    = fp32
engine.device_id    = 0
engine.cache_dir    = /tmp/visionpilot_trt_cache
engine.workspace_gb = 1.0

pipeline.initial_inference_check = true

# ─── Control / actuation (ROS2 drive path) ───────────────────────────────────
# Build with -DENABLE_ROS2_INTERFACE=ON to enable the ROS2 control loop.
# Topic names are middleware-agnostic — point them at whatever actuation sink
# and ego-state source are in use. Defaults shown; override per deployment.
# control.topic               = /control/ackermann_cmd   # ackermann_msgs/AckermannDriveStamped out
# control.vehicle_state_topic = /vehicle/odometry        # nav_msgs/Odometry in (ego speed)
# control.max_speed_mps       = 16.667                   # 60 km/h ceiling
# control.min_cruise_mps      = 0.0
# control.invert_steering     = false  # flip published steering sign (sink-specific)
# control.track_speed_only    = false  # default: forward the planner's real
#     acceleration (RSS / curve braking). Set true ONLY for sinks that dead-stop
#     on the planner's deceleration (e.g. CARLA native --ros2) — a sink trait.
#
# Simulator/vehicle-specific overlays live in their own config, e.g. CARLA:
#   config/vision_pilot_carla.conf.example
